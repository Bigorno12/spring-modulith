# not to search for config files in the parent directories
config.stopBubbling=true
# strip the "get"/"set" prefix from accessors !!
lombok.accessors.fluent=false
# make setters return this
lombok.accessors.chain=true
# to allow Jackson to deserialize @Value
lombok.anyConstructor.addConstructorProperties=true
# copy @Value from private final fields to generated @RequiredArgsConstructor
lombok.copyableAnnotations+=org.springframework.beans.factory.annotation.Value